# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
.vscode/
.idea/
*.swp
*.swo
*~

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# vercel
.vercel

# typescript
# Keep *.tsbuildinfo for incremental compilation caching
next-env.d.ts

# Build caches (keep for faster rebuilds)
# .next/cache/
# node_modules/.cache/

# environment variables
.env*
!.env.example

# genkit
.genkit/*

# firebase
firebase-debug.log
firestore-debug.log
.firebase/

# AI/ML
*.model
*.weights
*.pkl
*.joblib

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Temporary files
*.tmp
*.temp
*.log

# IDE specific files
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
*.code-workspace

# Package manager lock files (keep package-lock.json but ignore others if using different managers)
# yarn.lock
# pnpm-lock.yaml

# Local development
.local
.cache

# Backup files
*.backup
*.bak
*.orig

# Documentation build
/docs/build/
/docs/.docusaurus/

# Storybook
/storybook-static

# Bundle analyzer
.next/analyze/

# PWA files
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
**/public/worker-*.js.map