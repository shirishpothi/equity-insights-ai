# Google AI API Key (required for AI analysis)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_google_ai_api_key_here

# Supabase Configuration (required for authentication and data storage)
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://cnncodajczcuofseptkm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Firebase Configuration (optional - legacy)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:9002

# Development Settings
NODE_ENV=development

# Feature Flag Configuration
# Global feature flag settings
FEATURE_FLAGS_ENABLED=true
FEATURE_FLAGS_DEFAULT_ENABLED=false
FEATURE_FLAGS_LOG_USAGE=true

# Authentication Feature Flags
FEATURE_AUTH_GOOGLE_OAUTH=true
FEATURE_AUTH_SUPABASE_INTEGRATION=true
FEATURE_AUTH_USER_PROFILES=true
FEATURE_AUTH_SESSION_PERSISTENCE=true

# AI Analysis Feature Flags
FEATURE_AI_STOCK_ANALYSIS=true
FEATURE_AI_MARKET_INSIGHTS=true
FEATURE_AI_REPORT_GENERATION=true
FEATURE_AI_TICKER_SUGGESTIONS=true
FEATURE_AI_ADVANCED_ANALYTICS=false
FEATURE_AI_REAL_TIME_DATA=false

# UI/UX Feature Flags
FEATURE_UI_ANALYSIS_HISTORY=true
FEATURE_UI_PDF_EXPORT=true
FEATURE_UI_COPY_TO_CLIPBOARD=true
FEATURE_UI_DARK_THEME=true
FEATURE_UI_COLLAPSIBLE_SECTIONS=true
FEATURE_UI_NAVIGATION_IMPROVEMENTS=true

# Data Sources and External APIs
FEATURE_DATA_GEMINI_API=true
FEATURE_DATA_SUPABASE_OPERATIONS=true
FEATURE_DATA_EXTERNAL_MARKET_DATA=false
FEATURE_DATA_CACHING=true

# Performance and Monitoring
FEATURE_PERF_ANALYTICS_TRACKING=false
FEATURE_PERF_ERROR_MONITORING=true
FEATURE_PERF_PERFORMANCE_MONITORING=false

# Admin and Management
FEATURE_ADMIN_FEATURE_FLAG_MANAGEMENT=false
FEATURE_ADMIN_USER_MANAGEMENT=false
FEATURE_ADMIN_ANALYTICS_DASHBOARD=false
